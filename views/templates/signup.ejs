<%- include('../partials/navbar') %>

  <link rel="stylesheet" href="/css/signup.css" />

  <div class="signup-container">

    <h2 class="title">Student Registration</h2>

    <form action="/students/signup" method="POST" enctype="multipart/form-data" class="signup-form">

      <div class="form-group">
        <label>First Name</label>
        <input type="text" name="firstName" required />
      </div>

      <div class="form-group">
        <label>Last Name</label>
        <input type="text" name="lastName" required />
      </div>

      <div class="form-group">
        <label>User Name</label>
        <input type="text" name="userName" required />
      </div>

      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" required />
      </div>

      <div class="form-group">
        <label>University Email</label>
        <input type="email" name="uniEmail" placeholder="example@psu.edu.eg" required />
      </div>

      <div class="form-group">
        <label>National ID</label>
        <input type="text" name="nationalId" maxlength="14" required />
      </div>

      <div class="form-group">
        <label>Upload Scanned National ID</label>
        <input type="file" name="scannedId" accept="application/pdf" required />
      </div>

      <button type="submit" class="btn-submit">Create Account</button>

    </form>
  </div>

  <%- include('../partials/footer') %>